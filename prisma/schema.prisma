generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus { ACTIVE INACTIVE SUSPENDED }
enum ProjectStatus { DRAFT GPDP APPROVAL TENDER EXECUTION MONITORING PAYMENT AUDIT COMPLETED ON_HOLD }
enum TenderStatus { OPEN EVALUATION AWARDED CANCELLED }
enum DDResult { PASS FAIL WARNING }
enum RiskLevel { LOW MEDIUM HIGH CRITICAL }
enum LanguageCode { en hi }

model State {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  districts District[]
  createdAt DateTime   @default(now())
}

model District {
  id         String      @id @default(cuid())
  stateId    String
  state      State       @relation(fields: [stateId], references: [id])
  name       String
  code       String      @unique
  blocks     Block[]
  projects   Project[]
  createdAt  DateTime    @default(now())
}

model Block {
  id          String      @id @default(cuid())
  districtId  String
  district    District    @relation(fields: [districtId], references: [id])
  name        String
  code        String      @unique
  panchayats  Panchayat[]
  projects    Project[]
  createdAt   DateTime    @default(now())
}

model Panchayat {
  id          String      @id @default(cuid())
  blockId     String
  block       Block       @relation(fields: [blockId], references: [id])
  name        String
  code        String      @unique
  population  Int?
  projects    Project[]
  createdAt   DateTime    @default(now())
}

model User {
  id            String        @id @default(cuid())
  fullName      String
  email         String        @unique
  phone         String?       @unique
  hashedPassword String?
  status        UserStatus    @default(ACTIVE)
  preferredLang LanguageCode  @default(en)
  sessions      Session[]
  userRoles     UserRole[]
  createdProjects Project[]   @relation("ProjectCreatedBy")
  conversations CopilotConversation[]
  auditLogs     AuditLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  roles       RolePermission[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  @@unique([userId, roleId])
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String
  permissionId  String
  role          Role        @relation(fields: [roleId], references: [id])
  permission    Permission  @relation(fields: [permissionId], references: [id])
  @@unique([roleId, permissionId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  jwtId      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Scheme {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  ministry    String?
  projects    Project[]
  allocations FundingAllocation[]
}

model Project {
  id            String        @id @default(cuid())
  title         String
  description   String?
  status        ProjectStatus @default(DRAFT)
  districtId    String
  blockId       String
  panchayatId   String
  schemeId      String?
  budgetAmount  Decimal       @db.Decimal(14,2)
  startDate     DateTime?
  endDate       DateTime?
  createdById   String
  district      District      @relation(fields: [districtId], references: [id])
  block         Block         @relation(fields: [blockId], references: [id])
  panchayat     Panchayat     @relation(fields: [panchayatId], references: [id])
  scheme        Scheme?       @relation(fields: [schemeId], references: [id])
  createdBy     User          @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  milestones    ProjectMilestone[]
  tasks         ProjectTask[]
  tenders       Tender[]
  payments      Payment[]
  auditReports  AuditReport[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProjectMilestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  dueDate     DateTime?
  completedAt DateTime?
}

model ProjectTask {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  assignedToId String?
  assignedTo  User?     @relation(fields: [assignedToId], references: [id])
  title       String
  deadline    DateTime?
  isDone      Boolean   @default(false)
}

model Vendor {
  id              String    @id @default(cuid())
  legalName       String
  registrationNo  String?   @unique
  panNumber       String?   @unique
  gstNumber       String?   @unique
  districtFocus   String?
  panchayatFocus  String?
  experienceYears Int?
  documents       VendorDocument[]
  ddReports       DueDiligenceReport[]
  tenders         Tender[]
  createdAt       DateTime @default(now())
}

model VendorDocument {
  id            String   @id @default(cuid())
  vendorId       String
  vendor         Vendor   @relation(fields: [vendorId], references: [id])
  fileName       String
  fileUrl        String
  mimeType       String
  extractedText  String?
  uploadedAt     DateTime @default(now())
}

model DueDiligenceReport {
  id               String      @id @default(cuid())
  vendorId          String
  vendor            Vendor      @relation(fields: [vendorId], references: [id])
  riskScore         Int
  riskLevel         RiskLevel
  goNoGo            Boolean
  summary           String
  generatedByUserId String?
  checks            DDCheck[]
  signals           RiskSignal[]
  createdAt         DateTime    @default(now())
}

model DDCheck {
  id              String            @id @default(cuid())
  reportId         String
  report           DueDiligenceReport @relation(fields: [reportId], references: [id])
  checkType        String
  result           DDResult
  reason           String
  evidenceCitation String?
}

model RiskSignal {
  id          String            @id @default(cuid())
  reportId     String
  report       DueDiligenceReport @relation(fields: [reportId], references: [id])
  level       RiskLevel
  title       String
  description String
}

model Tender {
  id           String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  vendorId      String?
  vendor        Vendor?      @relation(fields: [vendorId], references: [id])
  status        TenderStatus @default(OPEN)
  bidAmount     Decimal?     @db.Decimal(14,2)
  publishedAt   DateTime?
  awardedAt     DateTime?
}

model Payment {
  id            String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  amount         Decimal  @db.Decimal(14,2)
  paidAt         DateTime?
  txnReference   String?  @unique
}

model AuditReport {
  id            String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  reportUrl      String?
  findings       String?
  score          Int?
  createdAt      DateTime @default(now())
}

model FundingAllocation {
  id          String   @id @default(cuid())
  schemeId     String
  scheme       Scheme   @relation(fields: [schemeId], references: [id])
  districtId   String?
  district     District? @relation(fields: [districtId], references: [id])
  financialYear String
  amount       Decimal   @db.Decimal(14,2)
}

model Stakeholder {
  id           String   @id @default(cuid())
  name         String
  type         String
  designation  String?
  district     String?
}

model VendorRelationship {
  id             String   @id @default(cuid())
  vendorId       String
  stakeholderId  String
  relationType   String
  confidence     Float
}

model CopilotConversation {
  id            String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  title          String?
  language       LanguageCode     @default(en)
  messages       CopilotMessage[]
  createdAt      DateTime         @default(now())
}

model CopilotMessage {
  id               String              @id @default(cuid())
  conversationId    String
  conversation      CopilotConversation @relation(fields: [conversationId], references: [id])
  role             String
  content          String
  confidenceScore  Float?
  citationsJson    Json?
  createdAt        DateTime            @default(now())
}

model AIInsight {
  id          String   @id @default(cuid())
  projectId    String?
  vendorId     String?
  type        String
  title       String
  detail      String
  confidence  Float
  createdAt   DateTime @default(now())
}

model EmbeddingDocument {
  id           String   @id @default(cuid())
  sourceType   String
  sourceId     String
  chunkText    String
  vectorRef    String
  createdAt    DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  action       String
  entityType   String
  entityId     String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())
}
